@page 
@model rockmuseet_og_gasolin.Pages.content.BandsModel
@{
    ViewData["Title"] = "Bands";
}



<!-- Carousel from bootstrap -->

<div class="container-fluid p-0">
    <div id="myCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="2500">

        <div class="carousel-inner">

            <!-- Slide 1 -->
            <div class="carousel-item active">
                <img src="~/images/gasolin.png" class="d-block w-100" onclick="window.location.href='/bands/gasolin'">

                <div class="carousel-caption" onclick="window.location.href='/bands/gasolin'">
                    <h5>Gasolin</h5>
                    <p>Most iconic big danish band</p>
                </div>
            </div>

            <!-- Slide 2 -->
            <div class="carousel-item">
                <img src="~/images/queen.png" class="d-block w-100" onclick="window.location.href='/bands/queen'">

                <div class="carousel-caption" onclick="window.location.href='/bands/queen'">
                    <h5>Queen</h5>
                    <p>Iconic band</p>
                </div>
            </div>
        </div>
    </div>
</div>



<!-- Section 2 - content box-->

<div class="content-container">
    
    <div class="text-and-photo-container">
        
        <div class="text-box">
            <h5>lær mere om</h5>
            <h1>vores band udstillinger</h1>
            <div style="width: 44px; height: 2px; background: #8b4a2e; margin-bottom: 1.4rem;"></div>
            <p>Rockmuseet rummer et bredt udvalg af udstillinger, der dykker ned i historien om både danske og internationale bands. 
                Her kan man opleve alt fra ikoniske koncertøjeblikke til personlige historier og originale genstande fra musikernes karrierer. 
                Museet giver et unikt indblik i, hvordan musikken har udviklet sig gennem tiden, og hvordan forskellige bands har sat deres præg på kulturen.</p>
            <p>Et godt eksempel er Gasolin, som er et af de mest betydningsfulde danske rockbands. I deres udstilling kan man lære om bandets rejse, 
                deres største hits og deres indflydelse på dansk rockmusik. Gennem billeder, lyd og genstande får man en levende oplevelse af deres tid 
                og betydning.</p>
            <p> Uanset om man er stor fan af rock eller bare nysgerrig, er der noget at opleve for alle på Rockmuseet.</p>
        </div>
        
        <img src="~/images/biography/franz-beckerlee/franz-beckerlee-1.png" class="image-biography">
        
    </div>
</div>



<!-- Section 3 - objects with "pop-ups" -->

<div class="content-container">
    
    <h2 class="title-with-top-line">Lær lidt mere om instrumenterne</h2>
    
    <div class="objects-row">
        
        <div class="objects-unit object-guitar" onclick="togglePopup(this)">
            <h3 class="objects-title">Guitar</h3>
            <p class="objects-text">tryk for at lære mere</p>
            
            <div class="object-popup">
                <p class="objects-text-hover">Guitaren er et af de vigtigste instrumenter i rockmusik. 
                    Den skaber både rytme og melodi og er ofte centrum i mange bands. 
                    Elguitaren har været med til at definere rockens lyd gennem tiden.</p>
            </div>
            
        </div>
        
        <div class="objects-unit object-keyboard" onclick="togglePopup(this)">
            <h3 class="objects-title">Keyboard</h3>
            <p class="objects-text">tryk for at lære mere</p>
            
            <div class="object-popup">
                <p class="objects-text-hover">Keyboardet giver musikken dybde og variation med mange forskellige lyde. 
                    Det bruges både til at skabe stemning og til at understøtte melodier. 
                    I moderne musik spiller det en stor rolle i både rock og pop.</p>
            </div>
            
        </div>
        
        <div class="objects-unit object-drums" onclick="togglePopup(this)">
            <h3 class="objects-title">Trommer</h3>
            <p class="objects-text">tryk for at lære mere</p>
            
            <div class="object-popup">
                <p class="objects-text-hover">Trommerne er fundamentet i musikken og styrer tempoet. 
                    De holder rytmen og binder bandet sammen. 
                    Uden trommer ville musikken mangle energi og struktur.</p>
            </div>
            
        </div>
        
    </div>
    
</div>



<!-- This script runs when you click on the object boxes-->
<!-- It just toggles the togglePopup mode to "active" -->

<script>
    function togglePopup(element) {
    element.classList.toggle("active");
    }
</script>